# Resend (https://resend.com) — used to email you when someone submits the contact form.
# Sign up, verify a sending domain (or use the resend.dev test domain while developing),
# and create an API key.
RESEND_API_KEY=

# The inbox that should receive contact-form notifications.
CONTACT_EMAIL=ashenafizewdie19@gmail.com

# Optional: must be an address on a domain you've verified in Resend.
# Defaults to onboarding@resend.dev (fine for testing, not for production).
CONTACT_FROM_EMAIL=

# Google Apps Script "Web app" URL that appends a row to your Google Sheet.
GOOGLE_SHEET_URL=
